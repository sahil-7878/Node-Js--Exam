<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= article.title %> - BlogVerse</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <%- include('navbar') %>

  <div class="container mt-4 mb-5">
    <div class="row justify-content-center">
      <div class="col-md-8">

        <!-- ===== Article Card ===== -->
        <div class="article-detail-card card mb-4">
          <div class="card-body">

            <!-- Title -->
            <h2 class="article-detail-title mb-3"><%= article.title %></h2>

            <!-- Author and Date -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
              <span class="author-badge fs-6">👤 <%= article.author.username %></span>
              <span class="date-badge">🗓️ <%= article.createdAt.toDateString() %></span>
            </div>

            <hr />

            <!-- Full Article Content -->
            <p class="article-content"><%= article.content %></p>

            <!-- Edit and Delete buttons (only for author or admin) -->
            <% if (currentUser && (currentUser.id === article.author._id.toString() || currentUser.role === 'admin')) { %>
              <hr />
              <div class="d-flex gap-2 flex-wrap">
                <a href="/article/edit/<%= article._id %>" class="btn btn-warning btn-sm">
                  ✏️ Edit
                </a>
                <form action="/article/delete/<%= article._id %>" method="POST"
                      onsubmit="return confirm('Are you sure you want to delete this article?')">
                  <button type="submit" class="btn btn-danger btn-sm">
                    🗑️ Delete
                  </button>
                </form>
              </div>
            <% } %>

          </div>
        </div>

        <!-- ===== Comments Card ===== -->
        <div class="comments-card card mb-4">
          <div class="card-body">

            <h5 class="mb-4">💬 Comments (<%= article.comments.length %>)</h5>

            <!-- Show existing comments -->
            <% if (article.comments.length === 0) { %>
              <p class="text-muted">No comments yet. Be the first! 👇</p>
            <% } else { %>
              <% article.comments.forEach(function(comment) { %>
                <div class="comment-item">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <span class="comment-author">👤 <%= comment.author.username %></span>
                      <span class="comment-date ms-2"><%= comment.createdAt.toDateString() %></span>
                      <p class="comment-text mb-0"><%= comment.text %></p>
                    </div>

                    <!-- Delete comment (only for comment author or admin) -->
                    <% if (currentUser && (currentUser.id === comment.author._id.toString() || currentUser.role === 'admin')) { %>
                      <form action="/article/<%= article._id %>/comment/<%= comment._id %>/delete" method="POST"
                            onsubmit="return confirm('Delete this comment?')">
                        <button type="submit" class="btn btn-outline-danger btn-sm ms-2">✕</button>
                      </form>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            <% } %>

            <!-- Add Comment Form (only for logged-in users) -->
            <% if (currentUser) { %>
              <hr />
              <h6 class="mb-3">Add a Comment</h6>
              <form action="/article/<%= article._id %>/comment" method="POST">
                <div class="mb-3">
                  <textarea
                    class="form-control"
                    name="text"
                    rows="3"
                    placeholder="Write your comment here..."
                    required
                  ></textarea>
                </div>
                <button type="submit" class="btn btn-primary btn-sm">
                  📤 Post Comment
                </button>
              </form>
            <% } else { %>
              <p class="text-muted mt-3">
                <a href="/login" class="text-decoration-none fw-bold">Login</a> to post a comment.
              </p>
            <% } %>

          </div>
        </div>

        <!-- Back Button -->
        <a href="/articles" class="btn btn-secondary">
          ← Back to Articles
        </a>

      </div>
    </div>
  </div>

  <footer>
    Made with ❤️ by <span>BlogVerse</span>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
