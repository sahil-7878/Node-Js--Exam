<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= article ? 'Edit Article' : 'Write Article' %> - BlogVerse</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <%- include('navbar') %>

  <div class="container mt-5 mb-5">
    <div class="row justify-content-center">
      <div class="col-md-8">

        <div class="article-detail-card card">
          <div class="card-body">

            <!-- Dynamic heading: Edit or Write New -->
            <h2 class="mb-1" style="font-family: 'Playfair Display', serif;">
              <%= article ? '✏️ Edit Article' : '📝 Write New Article' %>
            </h2>
            <p class="text-muted mb-4">
              <%= article ? 'Update your article below.' : 'Share your thoughts with the world!' %>
            </p>

            <!-- Form action changes based on create or edit -->
            <form action="<%= article ? '/article/edit/' + article._id : '/articles/create' %>" method="POST">

              <!-- Title Field -->
              <div class="mb-4">
                <label class="form-label">Article Title</label>
                <input
                  type="text"
                  class="form-control"
                  name="title"
                  placeholder="Enter a catchy title..."
                  value="<%= article ? article.title : '' %>"
                  required
                />
              </div>

              <!-- Content Field -->
              <div class="mb-4">
                <label class="form-label">Content</label>
                <textarea
                  class="form-control"
                  name="content"
                  rows="10"
                  placeholder="Write your article content here..."
                  required
                ><%= article ? article.content : '' %></textarea>
              </div>

              <!-- Submit and Cancel Buttons -->
              <div class="d-flex gap-3">
                <button type="submit" class="btn btn-primary px-4">
                  <%= article ? '💾 Update Article' : '🚀 Publish Article' %>
                </button>
                <a href="/articles" class="btn btn-secondary">Cancel</a>
              </div>

            </form>
          </div>
        </div>

      </div>
    </div>
  </div>

  <footer>
    Made with ❤️ by <span>BlogVerse</span>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
