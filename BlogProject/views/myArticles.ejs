<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Articles - BlogVerse</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <%- include('navbar') %>

  <div class="container mt-4 mb-5">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
      <div>
        <h2 style="font-family: 'Playfair Display', serif;">📋 My Articles</h2>
        <p class="text-muted mb-0">All articles written by you</p>
      </div>
      <a href="/articles/create" class="btn btn-primary">
        ✏️ Write New Article
      </a>
    </div>

    <!-- Empty State -->
    <% if (articles.length === 0) { %>
      <div class="alert alert-info text-center py-5">
        <h4>You haven't written any articles yet!</h4>
        <p>Click the button above to get started. ✍️</p>
      </div>

    <!-- Article List -->
    <% } else { %>
      <% articles.forEach(function(article) { %>
        <div class="my-article-row">

          <!-- Article Title and Date -->
          <div>
            <h5 class="mb-1 fw-bold"><%= article.title %></h5>
            <small class="text-muted">🗓️ <%= article.createdAt.toDateString() %></small>
          </div>

          <!-- Action Buttons -->
          <div class="d-flex gap-2 flex-wrap">
            <a href="/article/<%= article._id %>" class="btn btn-outline-primary btn-sm">👁️ View</a>
            <a href="/article/edit/<%= article._id %>" class="btn btn-warning btn-sm">✏️ Edit</a>
            <form action="/article/delete/<%= article._id %>" method="POST"
                  onsubmit="return confirm('Delete this article?')">
              <button type="submit" class="btn btn-danger btn-sm">🗑️ Delete</button>
            </form>
          </div>

        </div>
      <% }) %>
    <% } %>

  </div>

  <footer>
    Made with ❤️ by <span>BlogVerse</span>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
