<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>All Articles - BlogVerse</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>

  <%- include('navbar') %>

  <div class="container mt-4">

    <!-- Hero Banner -->
    <div class="hero-banner d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <h1>📰 Explore Articles</h1>
        <p class="mb-0">Read stories, ideas, and tutorials from our community.</p>
      </div>
      <% if (currentUser) { %>
        <a href="/articles/create" class="btn btn-light fw-bold px-4">
          ✏️ Write Article
        </a>
      <% } else { %>
        <a href="/login" class="btn btn-light fw-bold px-4">
          🔑 Login to Write
        </a>
      <% } %>
    </div>

    <!-- Article Count -->
    <p class="text-muted mb-4">
      Showing <strong><%= articles.length %></strong> article<%= articles.length !== 1 ? 's' : '' %>
    </p>

    <!-- Empty State -->
    <% if (articles.length === 0) { %>
      <div class="alert alert-info text-center py-4">
        <h4>No articles yet!</h4>
        <p class="mb-0">Be the first to write something amazing. 🚀</p>
      </div>

    <!-- Article Grid -->
    <% } else { %>
      <div class="row">
        <% articles.forEach(function(article) { %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="article-card card">
              <div class="card-body d-flex flex-column">

                <!-- Title -->
                <h5 class="card-title"><%= article.title %></h5>

                <!-- Short preview of content (max 120 characters) -->
                <p class="card-text flex-grow-1">
                  <%= article.content.substring(0, 120) %><%= article.content.length > 120 ? '...' : '' %>
                </p>

                <!-- Author and Date -->
                <div class="d-flex justify-content-between align-items-center mb-3 mt-2">
                  <span class="author-badge">👤 <%= article.author.username %></span>
                  <span class="date-badge">🗓️ <%= article.createdAt.toDateString() %></span>
                </div>

                <!-- Read More Button -->
                <a href="/article/<%= article._id %>" class="btn btn-outline-primary btn-sm w-100">
                  Read More →
                </a>

              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

  </div>

  <footer>
    Made with ❤️ by <span>BlogVerse</span>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
